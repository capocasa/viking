; First section is the taxpayer. Section name = "Vornamen Nachname"
; (last word = Nachname, rest = Vornamen).
[Hans Maier]
geburtsdatum = 01.01.1980
idnr         = 12345678901
steuernr     = 1234567890123
strasse      = Musterstr.
nr           = 1
plz          = 10115
ort          = Berlin
iban         = DE89370400440532013000
religion     = keine          ; keine, rk, ev, altkath, ev_ref, ... or numeric
beruf        = Software-Entwickler
; krankenkasse = privat       ; privat (default) or gesetzlich

; Income sources. Reserved names: freiberuf (Anlage S), gewerbe
; (Einzelgewerbe). Otherwise rechtsform is inferred from a legal-form
; suffix in the section name (GmbH, UG, KG, OHG, GbR, PartG, eK, eG,
; KGaA, SE, "GmbH & Co. KG", …). No suffix → Einzelgewerbe.
; Anlage KAP marker: `guenstigerpruefung` or `pauschbetrag`.

[freiberuf]
versteuerung    = ist         ; ist (Ist-Versteuerung) or soll
vorauszahlungen = 0

; [gewerbe]
; versteuerung    = ist
; vorauszahlungen = 0

; [Musterfirma GmbH]          ; rechtsform inferred from suffix: GmbH
; versteuerung    = soll

; [ibkr]
; guenstigerpruefung  = 1
; pauschbetrag        = 1000

; Kids. Marker: `verhaeltnis`. Section name = full name (last word =
; Nachname). First word of given names (lowercased) is the deduction-
; code prefix, e.g. lena174.
; [Lena Maier]
; geburtsdatum        = 15.03.2019
; idnr                = 02293417683
; verhaeltnis         = leiblich
; personb-verhaeltnis = leiblich
; personb-name        = Anna Mustermann
; familienkasse       = Berlin
