religion = keine              ; keine, rk, ev, altkath, ev_ref, ... or numeric
profession = Software-Entwickler
; kv_art = privat             ; privat (default) or gesetzlich

; Income source. income= selects the Anlage:
;   gewerbe   -> Anlage G (Gewerbebetrieb)
;   freiberuf -> Anlage S (Selbstaendige Arbeit)
;   kap       -> Anlage KAP (fill gains/tax inline)
; rechtsform: einzel, gmbh, ug, gbr, ohg, kg, ag, freiberuf, selbst, ...
; besteuerungsart: ist (Ist-Versteuerung) or soll (Soll-Versteuerung)
; Numeric codes still accepted for all of the above.
[freelance]
income = freiberuf
rechtsform = freiberuf
besteuerungsart = ist
vorauszahlungen = 0

; [ibkr]
; income = kap
; guenstigerpruefung = 1
; sparer_pauschbetrag = 1000

; One section per child. Section name is the firstname (used as the
; prefix in deductions.tsv, e.g. lena174).
; kindschaftsverhaeltnis / kindschaftsverhaeltnis_b: leiblich, pflege,
;   enkel (or 1, 2, 3). _b is the relationship to the other parent.
; parent_b_name: full name of the non-co-filing other parent. Required
;   on Einzelveranlagung when there's a second parent (ERiC plausi
;   100500048); emitted as E0501103 plus full-year Dauer/Art.
; familienkasse: Familienkasse responsible for Kindergeld.
