# Test mode (1=sandbox, 0=production)
TEST=1

# ERiC Library Configuration
# Download ERiC from: https://www.elster.de/elsterweb/entwickler/infoseite/eric

# Path to the ERiC shared library
ERIC_LIB_PATH=/path/to/ERiC/lib/libericapi.so

# Path to the ERiC plugins directory
ERIC_PLUGIN_PATH=/path/to/ERiC/plugins2

# Path for ERiC log files (optional, defaults to /tmp/eric_logs)
ERIC_LOG_PATH=/tmp/eric_logs

# Certificate Configuration
# Obtain a certificate from: https://www.elster.de/eportal/

# Path to your ELSTER certificate file (.pfx)
CERT_PATH=/path/to/certificate.pfx

# Certificate PIN (set one or the other)
CERT_PIN=your-certificate-pin
# CERT_PIN_CMD=pass show elster/cert-pin

# Tax Information
# Your 13-digit tax number (Steuernummer) in ELSTER format
# Format varies by state, check: https://www.elster.de/elsterweb/hilfe/steuernummer
STEUERNUMMER=1234567890123

# Sender Information (required for UStVA, EUeR, USt, message, iban commands)
DATENLIEFERANT_NAME=Hans Maier
DATENLIEFERANT_STRASSE=Musterstr. 1
DATENLIEFERANT_PLZ=12345
DATENLIEFERANT_ORT=Musterstadt

# USt (Annual VAT Return) Configuration
# BESTEUERUNGSART: 1=vereinbart (accrual), 2=vereinnahmt (cash), 3=mixed
BESTEUERUNGSART=2

# EUeR Configuration
# RECHTSFORM: 1=Einzelunternehmen
# EINKUNFTSART: 2=Gewerbebetrieb, 3=Selbstaendige Arbeit
RECHTSFORM=1
EINKUNFTSART=2

# ESt personal data, deductions, and KAP are now in viking.conf
# and input files (deductions.tsv, kap.tsv). See viking.conf.example.
